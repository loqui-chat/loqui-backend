DATABASE_URL=postgres://loqui:loqui@localhost:5432/loqui?sslmode=disable
HTTP_ADDR=:8080
NODE_ID=0
LOG_LEVEL=info
LOG_FORMAT=text
ENV=dev

# path to an ed25519 PEM. empty in dev = ephemeral key each start.
# generate: mkdir -p secrets && go run ./cmd/genkey > secrets/jwt_ed25519.pem
JWT_PRIVATE_KEY_FILE=secrets/jwt_ed25519.pem
ACCESS_TTL=15m
REFRESH_TTL=720h
