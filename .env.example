DATABASE_URL=postgres://loqui:loqui@localhost:5432/loqui?sslmode=disable
HTTP_ADDR=:8080
NODE_ID=0
LOG_LEVEL=info
LOG_FORMAT=text
ENV=dev

# ed25519 PEM for signing JWTs
# (empty in dev = ephemeral key each start)
#
# TODO: generate one with: go run ./cmd/genkey
JWT_PRIVATE_KEY=
ACCESS_TTL=15m
REFRESH_TTL=720h
